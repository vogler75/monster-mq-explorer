{
  "name": "monster-mqtt-explorer",
  "version": "1.0.0",
  "description": "High-performance MQTT client with topic tree visualization",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pwa": "vite build",
    "build:electron": "ELECTRON=1 vite build && electron-builder",
    "build:electron:mac": "ELECTRON=1 vite build && electron-builder --mac",
    "build:electron:win": "ELECTRON=1 vite build && electron-builder --win",
    "electron:preview": "ELECTRON=1 vite build && electron .",
    "preview": "vite preview",
    "test": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tanstack/solid-virtual": "^3.13.23",
    "idb-keyval": "^6.2.2",
    "mqtt": "^5.15.1",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.5.5",
    "source-map": "^0.7.6",
    "glob": "^13.0.6",
    "serialize-javascript": "^7.0.4",
    "@rollup/plugin-terser": "^1.0.0",
    "rimraf": "^6.1.3",
    "global-agent": "^4.1.3"
  },
  "build": {
    "appId": "com.monstermqtt.explorer",
    "productName": "Monster MQTT Explorer",
    "copyright": "Copyright © 2025",
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "icon": "public/icons/icon-512.png",
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "win": {
      "icon": "public/icons/icon-512.png",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
